@page
@model SugarEveSystem.Pages.Cotizaciones.CrearModel
@{
    ViewData["Title"] = "Nueva Cotización";
}

<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h2 class="text-primary fw-bold"><i class="fas fa-plus-circle me-2"></i> Nueva Cotización</h2>
    </div>
    <div class="col-md-6 text-end">
        <a asp-page="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i> Volver a Cotizaciones</a>
    </div>
</div>

<div class="card border-0 shadow-sm w-75 mx-auto">
    <div class="card-header bg-primary text-dark fw-bold">
        Datos de la Cotización
    </div>
    <div class="card-body bg-white rounded-bottom">
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Cotizacion.NombreCliente" class="form-label text-primary fw-bold">Nombre del Cliente</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-primary"><i class="fas fa-user"></i></span>
                    <input asp-for="Cotizacion.NombreCliente" class="form-control" required placeholder="Nombre completo" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cotizacion.TipoEvento" class="form-label text-primary fw-bold">Tipo de Evento</label>
                    <select asp-for="Cotizacion.TipoEvento" class="form-select" required>
                        <option value="">Seleccione el evento...</option>
                        <option value="Boda">Boda</option>
                        <option value="XV Años">XV Años</option>
                        <option value="Bautizo">Bautizo</option>
                        <option value="Primera Comunión">Primera Comunión</option>
                        <option value="Cumpleaños">Cumpleaños</option>
                        <option value="Evento Corporativo">Evento Corporativo</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Cotizacion.FechaEvento" class="form-label text-primary fw-bold">Fecha del Evento</label>
                    <input asp-for="Cotizacion.FechaEvento" class="form-control" type="date" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Cotizacion.MontoCotizado" class="form-label text-primary fw-bold">Monto Cotizado (MXN)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-primary">$</span>
                        <input asp-for="Cotizacion.MontoCotizado" class="form-control" type="number" step="0.01" min="0" required />
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Cotizacion.Estado" class="form-label text-primary fw-bold">Estado Inicial</label>
                    <select asp-for="Cotizacion.Estado" class="form-select" required>
                        <option value="Pendiente" selected>Pendiente (Por confirmar)</option>
                        <option value="Confirmado">Confirmado (Anticipo pagado)</option>
                        <option value="Cancelado">Cancelado</option>
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Cotizacion.Detalles" class="form-label text-primary fw-bold">Detalles o Notas Internas</label>
                <textarea asp-for="Cotizacion.Detalles" class="form-control" rows="3" placeholder="Información adicional relevante..."></textarea>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary btn-lg w-50">Guardar Cotización <i class="fas fa-save ms-2"></i></button>
            </div>
        </form>
    </div>
</div>
