@page
@model SugarEveSystem.Pages.Cotizaciones.IndexModel
@{
    ViewData["Title"] = "Cotizaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="fas fa-file-invoice-dollar me-2"></i> Gestión de Cotizaciones</h2>
    <a asp-page="Crear" class="btn btn-primary"><i class="fas fa-plus me-2"></i> Nueva Cotización</a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body bg-white rounded">
        @if (Model.Cotizaciones == null)
        {
            <div class="text-center py-5">
                <i class="fas fa-spinner fa-spin text-primary fa-2x mb-3"></i>
                <p class="text-muted">Cargando datos. Asegúrese de que Firebase está configurado.</p>
            </div>
            
            <!-- Vista previa estática cuando no hay Firebase -->
            <table class="table table-hover align-middle">
                <thead class="table-light text-primary">
                    <tr>
                        <th>Cliente</th>
                        <th>Evento</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>María López</td>
                        <td>Boda civil</td>
                        <td>2026-03-15</td>
                        <td>$4,500 MXN</td>
                        <td><span class="badge bg-warning text-dark">Pendiente</span></td>
                        <td><button class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></button></td>
                    </tr>
                </tbody>
            </table>
        }
        else if (Model.Cotizaciones.Count == 0)
        {
            <div class="text-center py-5">
                <i class="fas fa-file-signature fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">No hay cotizaciones registradas</h4>
                <p>Crea tu primera cotización para empezar a medir tus conversiones.</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead class="table-light text-primary">
                    <tr>
                        <th>Cliente</th>
                        <th>Evento</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var coti in Model.Cotizaciones)
                    {
                        <tr>
                            <td class="fw-bold">@coti.NombreCliente</td>
                            <td>@coti.TipoEvento</td>
                            <td>@coti.FechaEvento</td>
                            <td>$@coti.MontoCotizado.ToString("N2")</td>
                            <td>
                                @if(coti.Estado == "Confirmado")
                                {
                                    <span class="badge bg-success">@coti.Estado</span>
                                }
                                else if(coti.Estado == "Cancelado")
                                {
                                    <span class="badge bg-danger">@coti.Estado</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@coti.Estado</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
