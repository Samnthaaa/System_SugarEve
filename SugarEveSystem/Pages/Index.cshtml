@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@* ===== BIENVENIDA ===== *@
<div class="text-center mb-5">
    <h1 class="display-5 fw-bold" style="color: var(--sugar-dark);">
        Bienvenida al Sistema Sugar Eve <i class="fas fa-seedling px-2" style="color:var(--sugar-primary);"></i>
    </h1>
    <p class="lead text-muted">Gestión Operativa, Inventario y Marketing en un solo lugar.</p>
</div>

@* ===== KPIs ===== *@
<div class="row g-3 mb-5 justify-content-center">
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-radius:14px;">
            <div class="fs-1 mb-1"><i class="far fa-calendar-alt" style="color: var(--sugar-primary);"></i></div>
            <h3 class="fw-bold mb-0" style="color: var(--sugar-primary);">@Model.TotalEventesMes</h3>
            <p class="text-muted small mb-0">Eventos este mes</p>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-radius:14px;">
            <div class="fs-1 mb-1"><i class="fas fa-check-circle" style="color: #2e7d32;"></i></div>
            <h3 class="fw-bold mb-0" style="color: #2e7d32;">@Model.TotalConfirmadas</h3>
            <p class="text-muted small mb-0">Confirmadas</p>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm text-center py-3" style="border-radius:14px;">
            <div class="fs-1 mb-1"><i class="fas fa-hourglass-half" style="color: #f57f17;"></i></div>
            <h3 class="fw-bold mb-0" style="color: #f57f17;">@Model.TotalPendientes</h3>
            <p class="text-muted small mb-0">Pendientes</p>
        </div>
    </div>
</div>

@* ===== MÓDULOS PRINCIPALES ===== *@
<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px; overflow:hidden;">
            <div class="card-header border-0 fw-bold d-flex align-items-center gap-2"
                 style="background:linear-gradient(135deg,#fce4ec,#f8bbd0);">
                <i class="fas fa-box" style="color:#e91e8c;"></i>
                <span style="color:var(--sugar-dark);">Inventario Actual</span>
            </div>
            <div class="card-body bg-white">
                <p class="small text-muted">Control de bases, globos y materiales con códigos.</p>
                <a asp-page="/Inventario/Index" class="btn w-100 fw-bold mt-2"
                   style="background:linear-gradient(90deg,#f48fb1,#e91e8c);color:white;border-radius:10px;border:none;">
                    <i class="fas fa-box-open me-2"></i>Ver Inventario
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px; overflow:hidden;">
            <div class="card-header border-0 fw-bold d-flex align-items-center gap-2"
                 style="background:linear-gradient(135deg,#fce4ec,#f8bbd0);">
                <i class="fas fa-tasks" style="color:#e91e8c;"></i>
                <span style="color:var(--sugar-dark);">Servicios</span>
            </div>
            <div class="card-body bg-white">
                <p class="small text-muted">Checklists y cotizaciones por tipo de servicio.</p>
                <a asp-page="/Checklists/Index" class="btn w-100 fw-bold mt-2"
                   style="background:linear-gradient(90deg,#f48fb1,#e91e8c);color:white;border-radius:10px;border:none;">
                    <i class="fas fa-clipboard-check me-2"></i>Ver Servicios
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm" style="border-radius:14px; overflow:hidden;">
            <div class="card-header border-0 fw-bold d-flex align-items-center gap-2"
                 style="background:linear-gradient(135deg,#fce4ec,#f8bbd0);">
                <i class="fas fa-file-invoice-dollar" style="color:#e91e8c;"></i>
                <span style="color:var(--sugar-dark);">Cotizaciones</span>
            </div>
            <div class="card-body bg-white">
                <p class="small text-muted">Registra cotizaciones y mide tu tasa de conversión.</p>
                <a asp-page="/Cotizaciones/Index" class="btn w-100 fw-bold mt-2"
                   style="background:linear-gradient(90deg,#f48fb1,#e91e8c);color:white;border-radius:10px;border:none;">
                    <i class="fas fa-chart-line me-2"></i>Ver Cotizaciones
                </a>
            </div>
        </div>
    </div>
</div>
