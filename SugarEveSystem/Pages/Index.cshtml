@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mb-4">
    <h1 class="display-4 text-primary fw-bold">Bienvenido al Sistema Sugar Eve</h1>
    <p class="lead">Gestión Operativa, Inventario y Marketing en un solo lugar.</p>
</div>

<div class="row g-4">
    <!-- Inventario Card -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-primary text-dark fw-bold">
                <i class="fas fa-box me-2"></i> Inventario Actual
            </div>
            <div class="card-body bg-white rounded-bottom">
                <h5 class="card-title text-primary">Control de Bases y Globos</h5>
                <p class="card-text">Revisa y administra el stock con lector de códigos o QR.</p>
                <a asp-page="/Inventario/Index" class="btn btn-primary w-100">Ver Inventario</a>
            </div>
        </div>
    </div>

    <!-- Servicios y Checklists Card -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-primary text-dark fw-bold">
                <i class="fas fa-tasks me-2"></i> Servicios
            </div>
            <div class="card-body bg-white rounded-bottom">
                <h5 class="card-title text-primary">Checklists Digitales</h5>
                <p class="card-text">Asegura la calidad con checklists por cada tipo de servicio.</p>
                <a asp-page="/Checklists/Index" class="btn btn-primary w-100">Ver Servicios</a>
            </div>
        </div>
    </div>

    <!-- Cotizaciones Card -->
    <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-primary text-dark fw-bold">
                <i class="fas fa-file-invoice-dollar me-2"></i> Cotizaciones
            </div>
            <div class="card-body bg-white rounded-bottom">
                <h5 class="card-title text-primary">Conversión de Ventas</h5>
                <p class="card-text">Administra cotizaciones y mide el retorno de inversión.</p>
                <a asp-page="/Cotizaciones/Index" class="btn btn-primary w-100">Ver Cotizaciones</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-dark fw-bold">
                <i class="fas fa-chart-line me-2"></i> Resumen Rápido (KPIs)
            </div>
            <div class="card-body bg-white rounded-bottom">
                <div class="row text-center">
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <h3 class="text-primary fw-bold">0</h3>
                        <p class="text-muted">Eventos en el Mes</p>
                    </div>
                    <div class="col-sm-4 border-start mb-3 mb-sm-0">
                        <h3 class="text-primary fw-bold">0</h3>
                        <p class="text-muted">Cotizaciones Confirmadas</p>
                    </div>
                    <div class="col-sm-4 border-start">
                        <h3 class="text-primary fw-bold">0</h3>
                        <p class="text-muted">Alertas de Inventario</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
