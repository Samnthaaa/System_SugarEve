@page
@model SugarEveSystem.Pages.Inventario.IndexModel
@{
    ViewData["Title"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="fas fa-boxes me-2"></i> Inventario de Bases y Globos</h2>
    <a asp-page="Crear" class="btn btn-primary"><i class="fas fa-plus me-2"></i> Nuevo Artículo</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body bg-white rounded">
        @if (Model.Inventario == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Asegúrate de configurar Firebase. Mostrando diseño base por ahora.</p>
            </div>
            
            <!-- Vista previa estática cuando no hay Firebase Configurado aún -->
            <table class="table table-hover align-middle">
                <thead class="table-light text-primary">
                    <tr>
                        <th>Foto</th>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><div style="width: 50px; height: 50px; background-color: var(--primary-pink); border-radius: 5px;"></div></td>
                        <td><span class="badge bg-secondary">B-001</span></td>
                        <td>Base cilíndrica blanca</td>
                        <td>Base</td>
                        <td><h4><span class="badge bg-success">5</span></h4></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        }
        else if (Model.Inventario.Count == 0)
        {
            <div class="text-center py-5">
                <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">El inventario está vacío</h4>
                <p>Comienza agregando tus primeros productos.</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead class="table-light text-primary">
                    <tr>
                        <th>Foto</th>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Inventario)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.FotografiaUrl))
                                {
                                    <img src="@item.FotografiaUrl" alt="Foto" style="max-width: 50px; max-height: 50px; border-radius: 5px;" />
                                }
                                else
                                {
                                    <div style="width: 50px; height: 50px; background-color: var(--primary-pink); border-radius: 5px;" class="d-flex align-items-center justify-content-center text-white"><i class="fas fa-image"></i></div>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@item.Codigo</span></td>
                            <td>@item.Descripcion</td>
                            <td>@item.TipoMaterial</td>
                            <td>
                                <h4>
                                    <span class="badge @(item.CantidadDisponible > 0 ? "bg-success" : "bg-danger")">
                                        @item.CantidadDisponible
                                    </span>
                                </h4>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
