@page
@model SugarEveSystem.Pages.Checklists.IndexModel
@{
    ViewData["Title"] = "Servicios";
}

<div class="text-center mb-5">
    <h2 class="fw-bold" style="color: var(--sugar-dark);">
        <i class="fas fa-star me-2" style="color: var(--sugar-primary);"></i>
        Servicios Sugar Eve
    </h2>
    <p class="text-muted">Selecciona un servicio para ver y gestionar sus checklists.</p>
</div>

<div class="row g-4">
    <!-- Backdrops -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/Backdrops/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #f8bbd0, #f48fb1);">
                        <i class="fas fa-camera-retro fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Backdrops</h5>
                    <p class="text-muted small">Fondos decorativos personalizados para cualquier tipo de evento.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Miniferia -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/Miniferia/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #fce4ec, #f48fb1);">
                        <i class="fas fa-ferris-wheel fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Miniferia</h5>
                    <p class="text-muted small">Estaciones de juego y diversión para los invitados de todas las edades.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Barra de Snacks -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/BarraSnacks/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #f8bbd0, #e91e8c);">
                        <i class="fas fa-cookie-bite fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Barra de Snacks</h5>
                    <p class="text-muted small">Botanas y snacks decorativamente presentados para el evento.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Mesa de Dulces -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/MesaDulces/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #ffd1dc, #ff85a1);">
                        <i class="fas fa-candy-cane fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Mesa de Dulces</h5>
                    <p class="text-muted small">Mesa temática con dulces a granel y decoración personalizada.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Estación de Algodones -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/Algodones/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #fce4ec, #ff80ab);">
                        <i class="fas fa-cloud fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Estación de Algodones</h5>
                    <p class="text-muted small">Algodón de azúcar en colores y sabores para el deleite de tus invitados.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Estación de Palomitas -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/Palomitas/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #f8bbd0, #ec407a);">
                        <i class="fas fa-blender fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Estación de Palomitas</h5>
                    <p class="text-muted small">Palomitas frescas con variedad de sazonadores para el evento.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Estación de Churros -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/Churros/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #ffd1dc, #e91e8c);">
                        <i class="fas fa-ice-cream fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Estación de Churros</h5>
                    <p class="text-muted small">Churros calientes con azúcar, canela y salsas para dipping.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>

    <!-- Catálogo de Paneles -->
    <div class="col-md-6 col-lg-3">
        <a asp-page="/Servicios/CatalogoPaneles/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 service-card">
                <div class="card-body text-center py-4">
                    <div class="service-icon mb-3" style="background: linear-gradient(135deg, #fce4ec, #ad1457);">
                        <i class="fas fa-th-large fa-2x text-white"></i>
                    </div>
                    <h5 class="fw-bold" style="color: var(--sugar-dark);">Catálogo de Paneles</h5>
                    <p class="text-muted small">Paneles decorativos personalizados para ambientar cualquier espacio.</p>
                </div>
                <div class="card-footer border-0 bg-transparent text-center pb-3">
                    <span class="badge px-3 py-2" style="background-color: var(--sugar-primary); color: var(--sugar-dark);">
                        Ver Checklists <i class="fas fa-chevron-right ms-1"></i>
                    </span>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .service-icon {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        box-shadow: 0 4px 12px rgba(244, 143, 177, 0.4);
    }
    .service-card {
        transition: transform 0.22s ease, box-shadow 0.22s ease;
        border-radius: 16px !important;
        cursor: pointer;
    }
    .service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 28px rgba(244, 143, 177, 0.35) !important;
    }
</style>
