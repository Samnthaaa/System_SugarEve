@page
@model SugarEveSystem.Pages.Checklists.IndexModel
@{
    ViewData["Title"] = "Checklists de Servicios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="fas fa-clipboard-check me-2"></i> Servicios (Checklists)</h2>
    <button class="btn btn-primary" disabled><i class="fas fa-plus me-2"></i> Nuevo Servicio</button>
</div>

<div class="row g-4">
    @if (Model.Servicios == null)
    {
        <div class="col-12 text-center py-5">
            <i class="fas fa-spinner fa-spin text-primary fa-2x mb-3"></i>
            <p class="text-muted">Cargando listas. Asegúrate de configurar Firebase...</p>
        </div>

        <!-- Vista previa estática Dummy -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-dark fw-bold d-flex justify-content-between">
                    <span>Barra de Snacks - Boda Ana y Carlos</span>
                    <span class="badge bg-warning text-dark">Montaje</span>
                </div>
                <div class="card-body bg-white">
                    <p class="mb-1"><strong>Responsable:</strong> María</p>
                    <div class="progress mb-3" style="height: 10px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 75%;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item px-0 border-0 py-1"><i class="fas fa-check-circle text-success me-2"></i> Base cilíndrica blanca (Completado)</li>
                        <li class="list-group-item px-0 border-0 py-1"><i class="fas fa-check-circle text-success me-2"></i> Globos pastel (Completado)</li>
                        <li class="list-group-item px-0 border-0 py-1"><i class="far fa-circle text-muted me-2"></i> Dulces a granel (Pendiente)</li>
                    </ul>
                    <a href="#" class="btn btn-outline-primary btn-sm w-100">Ver Detalles Completos</a>
                </div>
            </div>
        </div>
    }
    else if (Model.Servicios.Count == 0)
    {
        <div class="col-12 text-center py-5 bg-white rounded shadow-sm">
            <i class="fas fa-clipboard-list fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No hay checklists activos</h4>
            <p>Los checklists aparecerán aquí cuando se programen servicios.</p>
        </div>
    }
    else
    {
        @foreach (var srv in Model.Servicios)
        {
            var completados = srv.Materiales?.Count(m => m.Completado) ?? 0;
            var totales = srv.Materiales?.Count ?? 1;
            var porcentaje = (int)((double)completados / (totales == 0 ? 1 : totales) * 100);

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-primary text-dark fw-bold d-flex justify-content-between">
                        <span class="text-truncate">@srv.TituloServicio</span>
                        @if(srv.ConfirmacionFinal)
                        {
                            <span class="badge bg-success">Finalizado</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">@srv.Estado</span>
                        }
                    </div>
                    <div class="card-body bg-white">
                        <p class="mb-1 text-truncate"><strong>Evento:</strong> @srv.EventoAsociado</p>
                        <p class="mb-1"><strong>Responsable:</strong> @srv.Responsable</p>
                        
                        <div class="d-flex justify-content-between text-muted small mt-3 mb-1">
                            <span>Progreso de Materiales</span>
                            <span>@porcentaje%</span>
                        </div>
                        <div class="progress mb-3" style="height: 8px;">
                            <div class="progress-bar @(porcentaje == 100 ? "bg-success" : "bg-primary")" role="progressbar" style="width: @porcentaje%;" aria-valuenow="@porcentaje" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <ul class="list-group list-group-flush mb-3 text-truncate">
                            @if(srv.Materiales != null)
                            {
                                @foreach (var mat in srv.Materiales.Take(3))
                                {
                                    <li class="list-group-item px-0 border-0 py-1 text-truncate">
                                        @if(mat.Completado)
                                        {
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-circle text-muted me-2"></i>
                                        }
                                        @mat.Descripcion
                                    </li>
                                }
                                @if(srv.Materiales.Count > 3)
                                {
                                    <li class="list-group-item px-0 border-0 py-1 text-muted text-center small">
                                        ... y @(srv.Materiales.Count - 3) más
                                    </li>
                                }
                            }
                        </ul>
                        <a href="#" class="btn btn-outline-primary btn-sm w-100 disabled">Ver Editable (En Desarrollo)</a>
                    </div>
                </div>
            </div>
        }
    }
</div>
